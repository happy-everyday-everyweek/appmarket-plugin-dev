    <theme>
      <title>春节精选</title>
      <subtitle>2026 春节应用推荐</subtitle>
      <cover>https://example.com/spring.jpg</cover>
      <appId>com.example.app1</appId>
      <schedule>
        <startDate>2026-02-08</startDate>
        <endDate>2026-02-22</endDate>
      </schedule>
    </theme>
  </themes>
</dataSource>
